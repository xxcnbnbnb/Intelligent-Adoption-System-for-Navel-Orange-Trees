# 应用基础配置
# ===================================

# 运行环境：development (开发环境) / production (生产环境) / test (测试环境)
NODE_ENV=development

# 服务器监听端口
PORT=3000


# 用户端数据库配置
# ===================================

# 数据库主机地址
DB_HOST=localhost

# 数据库端口
DB_PORT=3306

# 数据库用户名
DB_USER=root

# 数据库密码
DB_PASSWORD=xxc1224821237

# 数据库名称
DB_NAME=orange_user


# 管理员端数据库配置
# ===================================

# 管理员数据库主机地址
ADMIN_DB_HOST=localhost

# 管理员数据库端口
ADMIN_DB_PORT=3306

# 管理员数据库用户名
ADMIN_DB_USER=root

# 管理员数据库密码
ADMIN_DB_PASSWORD=xxc1224821237

# 管理员数据库名称
ADMIN_DB_NAME=orange_admin


# JWT认证配置
# ===================================

# JWT密钥，用于签名和验证JWT令牌
# 生产环境必须使用强密钥并定期更换
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# JWT令牌过期时间
# 格式：数字 + 单位（s=秒，m=分钟，h=小时，d=天）
JWT_EXPIRES_IN=7d


# 支付宝配置
# ===================================

# 支付宝应用ID
# 在支付宝开放平台创建应用后获取
ALIPAY_APP_ID=your_alipay_app_id

# 支付宝应用私钥
# 用于签名请求，必须保密
ALIPAY_PRIVATE_KEY=your_alipay_private_key

# 支付宝公钥
# 用于验证支付宝回调签名
ALIPAY_PUBLIC_KEY=your_alipay_public_key


# 微信支付配置
# ===================================

# 微信应用ID
# 在微信公众平台或开放平台创建应用后获取
WECHAT_APP_ID=your_wechat_app_id

# 微信应用密钥
# 用于调用微信API，必须保密
WECHAT_APP_SECRET=your_wechat_app_secret


# Redis缓存配置
# ===================================

# Redis服务器地址
REDIS_HOST=localhost

# Redis服务器端口
REDIS_PORT=6379

# Redis密码
# 如果Redis设置了密码则需要提供
REDIS_PASSWORD=


# 日志配置
# ===================================

# 日志级别：error (只记录错误) / warn (记录警告和错误) / info (记录信息、警告和错误) / debug (记录所有级别)
LOG_LEVEL=info

# 日志文件目录
# 相对于项目根目录的路径
LOG_DIR=./logs


# 文件上传配置
# ===================================

# 文件上传目录
# 相对于项目根目录的路径
UPLOAD_DIR=./uploads

# 最大文件大小（字节）
# 默认为10MB (10485760字节)
MAX_FILE_SIZE=10485760